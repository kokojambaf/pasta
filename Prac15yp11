DROP TRIGGER IF EXISTS `trg_composition_after_insert`;
DELIMITER $$
CREATE TRIGGER `trg_composition_after_insert`
AFTER INSERT ON `Books_has_Orders`
FOR EACH ROW
BEGIN
    SELECT COALESCE(SUM(bho.`Count` * b.`price`), 0)
      INTO @orderCost
    FROM `Books_has_Orders` bho
    JOIN `Books` b ON b.`idBook` = bho.`Books_idBook`
    WHERE bho.`Orders_idOrder` = NEW.`Orders_idOrder`;
END$$
DELIMITER ;





