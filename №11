        print(s)

    #2
    text2 = input("\n5.2 Введите строку для замены слов/фраз:\n")
    replaced = censor_bad_words(text2)
    print("Результат замены:")
    print(replaced)

    #3
    text3 = input("\n5.3 Введите строку для поиска дат:\n")
    dates = find_dates(text3)
    print("Найденные даты:")
    for d in dates:
        print(d)

    #4
    while True:
