// 5.2 Подключение внешнего IronPython-скрипта в C#
// NuGet: IronPython, DynamicLanguageRuntime
// Файлы:
// 1) Program.cs (этот код)
// 2) process_numbers.py (скрипт ниже)

using System;
using System.Collections.Generic;
using IronPython.Hosting;
using Microsoft.Scripting.Hosting;

class Program
{
    static void Main()
    {
        // Данные из C#
        var numbers = new List<int> { 1, 2, 3, 4, 5 };

        // Создаем движок IronPython
        ScriptEngine engine = Python.CreateEngine();
        ScriptScope scope = engine.CreateScope();

        // Передаем данные в скрипт
        scope.SetVariable("input_data", numbers);

        // Выполняем внешний .py файл
        // Укажи свой путь, если файл лежит не рядом с exe:
        // engine.ExecuteFile(@"C:\path\to\process_numbers.py", scope);
        engine.ExecuteFile("process_numbers.py", scope);

        // Забираем output из Python
        dynamic output = scope.GetVariable("output");

        // Чтение результатов
        var squared = output["squared"];
        int sum = output["sum"];
        int count = output["count"];

        Console.WriteLine("Результат из Python:");
        Console.Write("squared: ");
        foreach (var n in squared)
            Console.Write(n + " ");
        Console.WriteLine();

        Console.WriteLine($"sum: {sum}");
        Console.WriteLine($"count: {count}");
    }
}



