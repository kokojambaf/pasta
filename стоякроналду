# Словарь областей и городов
regions = {
    "Архангельская область": ["Архангельск", "Новодвинск", "Северодвинск", "Шенкурск", "Котлас"],
    "Ленинградская область": ["Санкт-Петербург", "Пушкин", "Павловск"]
}

# Запрос количества городов
n = int(input("Введите количество городов: "))

# Создаём обратный словарь (город -> область)
city_to_region = {}
for region, cities in regions.items():
    for city in cities:
        city_to_region[city] = region

# Запрашиваем города и выводим результат
print("\nРезультат:")
for i in range(n):
    city = input(f"Введите город {i+1}: ")
    if city in city_to_region:
        print(city_to_region[city])
    else:
        print(f"Город '{city}' не найден")
