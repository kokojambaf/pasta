DROP TRIGGER IF EXISTS `trg_orders_after_delete`;
DELIMITER $$
CREATE TRIGGER `trg_orders_after_delete`
AFTER DELETE ON `Orders`
FOR EACH ROW
BEGIN

INSERT INTO `Logs` (`tableName`, `operationType`, `eventDateTime`, `dbUser`)
    VALUES ('Orders', 'DELETE', NOW(), CURRENT_USER());
    DELETE c
    FROM `Customers` c
    LEFT JOIN `Orders` o ON o.`idCustomer` = c.`idCustomer`
    WHERE o.`idOrder` IS NULL;
END$$
DELIMITER ;

