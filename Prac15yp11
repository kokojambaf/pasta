USE `Markets`;
-- 1
DROP TABLE IF EXISTS `DeletedCustomers`;
CREATE TABLE `DeletedCustomers` (
    `idCustomer` INT NOT NULL,
    `login` VARCHAR(100) NOT NULL,
    `surname` VARCHAR(100) NOT NULL,
    `firstname` VARCHAR(100) NOT NULL,
    `adress` VARCHAR(255) NOT NULL,
    `phone` VARCHAR(50) NULL,
    `deletedAt` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);
DROP TRIGGER IF EXISTS `trg_customers_after_delete`;
DELIMITER $$
CREATE TRIGGER `trg_customers_after_delete`
AFTER DELETE ON `Customers`
FOR EACH ROW
BEGIN
    INSERT INTO `DeletedCustomers`
    (`idCustomer`, `login`, `surname`, `firstname`, `adress`, `phone`, `deletedAt`)
    VALUES
    (OLD.`idCustomer`, OLD.`login`, OLD.`surname`, OLD.`firstname`, OLD.`adress`, OLD.`phone`, NOW());
END$$
DELIMITER ;

-- 2

DROP TABLE IF EXISTS `Logs`;
CREATE TABLE `Logs` (
    `idLog` INT NOT NULL AUTO_INCREMENT,
    `tableName` VARCHAR(50) NOT NULL,
    `operationType` VARCHAR(10) NOT NULL,
    `eventDateTime` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    `dbUser` VARCHAR(100) NOT NULL,
    PRIMARY KEY (`idLog`)
);

DROP TRIGGER IF EXISTS `trg_books_after_insert`;
DROP TRIGGER IF EXISTS `trg_books_after_update`;
DROP TRIGGER IF EXISTS `trg_books_after_delete`;
DELIMITER $$
CREATE TRIGGER `trg_books_after_insert`
AFTER INSERT ON `Books`
FOR EACH ROW
BEGIN
    INSERT INTO `Logs` (`tableName`, `operationType`, `eventDateTime`, `dbUser`)
    VALUES ('Books', 'INSERT', NOW(), CURRENT_USER());
END$$
CREATE TRIGGER `trg_books_after_update`
AFTER UPDATE ON `Books`
FOR EACH ROW
BEGIN
    INSERT INTO `Logs` (`tableName`, `operationType`, `eventDateTime`, `dbUser`)
    VALUES ('Books', 'UPDATE', NOW(), CURRENT_USER());
END$$
CREATE TRIGGER `trg_books_after_delete`
AFTER DELETE ON `Books`
FOR EACH ROW
BEGIN
    INSERT INTO `Logs` (`tableName`, `operationType`, `eventDateTime`, `dbUser`)
    VALUES ('Books', 'DELETE', NOW(), CURRENT_USER());
END$$
DELIMITER ;

