        choice = input("Ваш выбор: ").strip()

        if choice == "1":
            task_5_1()
        elif choice == "2":
            task_5_2()
        elif choice == "3":
            task_5_3()
        elif choice == "4":
            task_5_4()
        elif choice == "5":
            task_5_5()
