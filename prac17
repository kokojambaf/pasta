using System;
using System.IO;

namespace FileSystemLib
{
    public class FileSystemService
    {
        public void CreateFile(string path, string content)
        {
            File.WriteAllText(path, content);
        }

        public string ReadFile(string path)
        {
            return File.ReadAllText(path);
        }

        public void UpdateFile(string path, string newContent)
        {
            File.WriteAllText(path, newContent);
        }

        public void DeleteFile(string path)
        {
            if (File.Exists(path))
            {
                File.Delete(path);
            }
        }
    }
}



# pip install pythonnet
import os
import clr

# Путь к собранной DLL
DLL_PATH = r"C:\path\to\FileSystemLib.dll"  # поменяй на свой

clr.AddReference(DLL_PATH)

from FileSystemLib import FileSystemService

def test_filesystem_interaction():
    service = FileSystemService()

    test_file = "test_from_python_and_csharp.txt"

    # CREATE
    print("CREATE...")
    service.CreateFile(test_file, "Hello from C# called by Python")
    print("Exists after create:", os.path.exists(test_file))

    # READ
    print("READ...")
    content = service.ReadFile(test_file)
    print("Content:", content)

    # UPDATE
    print("UPDATE...")
    service.UpdateFile(test_file, "Updated text")
    updated = service.ReadFile(test_file)
    print("Updated content:", updated)

    # DELETE
    print("DELETE...")
    service.DeleteFile(test_file)
    print("Exists after delete:", os.path.exists(test_file))

if __name__ == "__main__":
    test_filesystem_interaction()



